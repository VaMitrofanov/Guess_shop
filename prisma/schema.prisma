// schema.prisma
generator client {
  provider      = "prisma-client-js"
  // engineType=library is the default in Prisma 7, declared explicitly
  // because the project guidelines require it for cross-platform build
  // reproducibility (Mac M1 dev → Linux x86 production).
  engineType    = "library"
  // Generate engines for both the dev host (native) and the Linux runtime
  // image. Without this, `prisma migrate deploy` from the container fails
  // with "Engine binary not found" on Debian (bookworm-slim => openssl 3.x).
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id @default(cuid())
  vkId               String?   @unique
  tgId               String?   @unique
  email              String?   @unique
  password           String?
  name               String?
  image              String?
  balance            Int       @default(0)
  role               String    @default("USER")
  reviewBonusClaimed Boolean   @default(false)
  orders             Order[]
  wbCodes            WbCode[]
  wbOrders           WbOrder[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  name        String
  robuxAmount Int
  rubPrice    Float
  type        String
  isActive    Boolean  @default(true)
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  FAILED
}

model Order {
  id                 String      @id @default(cuid())
  userId             String?
  user               User?       @relation(fields: [userId], references: [id])
  customerRobloxUser String
  productId          String
  product            Product     @relation(fields: [productId], references: [id])
  amountRUB          Float
  amountRobux        Int
  tinkoffPaymentID   String?     @unique
  paymentUrl         String?
  status             OrderStatus @default(PENDING)
  botStatus          String?
  externalId         String?
  gamepassId         String?
  method             String

  // ── Acceptance of public offer (ст. 437–438 ГК РФ + ФЗ-152) ─────────────
  // Captured server-side at the moment /api/orders/create accepts the
  // request, so the timestamp/IP/version triple is independent of anything
  // the client could forge after the fact. Nullable for backwards-compat
  // with rows created before this migration.
  termsAcceptedAt    DateTime?
  termsVersion       String?
  termsIpAddress     String?

  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

enum Platform {
  VK
  TG
}

enum WbOrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
}

/// WB withdrawal order: tracks gamepass link submissions from WB card buyers.
model WbOrder {
  id              String        @id @default(cuid())
  amount          Int
  gamepassUrl     String
  status          WbOrderStatus @default(PENDING)
  platform        Platform
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  wbCode          String
  adminId         String?
  rejectionReason String?
  /// Snapshot of the purchase rate (R$/₽) at the time of fulfillment.
  /// Allows accurate historical profit calculations.
  purchaseRate    Float?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
  @@index([status])
  @@index([wbCode])
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id         String   @id @default(cuid())
  author     String
  content    String
  rating     Int      @default(5)
  date       String
  isVerified Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// Stores the latest scraped data from each supplier marketplace.
model MarketRate {
  id            String   @id @default(cuid())
  provider      String   @unique
  rateUSD       Float
  inventory     Int
  maxLimit      Int
  purchaseRate  Float?
  accountsCount Int?
  updatedAt     DateTime @updatedAt

  @@index([provider])
}

/// Historical rate snapshots — one row per parser cycle per provider.
/// Used for trend analysis, sub-$4 episode tracking, and admin dashboards.
model RateSnapshot {
  id            String   @id @default(cuid())
  provider      String
  rateUSD       Float
  inventory     Int
  maxLimit      Int
  purchaseRate  Float?
  accountsCount Int?
  createdAt     DateTime @default(now())

  @@index([provider, createdAt])
  @@index([rateUSD, createdAt])
}

/// Global system settings — single-row config table.
/// Always upsert with id = "global".
model GlobalSettings {
  id           String   @id @default("global")
  usdToRub     Float
  /// Manual purchase rate in ₽ per R$ — set by admin via bot.
  purchaseRate Float?
  lastUpdated  DateTime @updatedAt
}

/// Activation codes printed on Wildberries card inserts.
model WbCode {
  id                 String    @id @default(cuid())
  code               String    @unique
  denomination       Int
  isUsed             Boolean   @default(false)
  usedAt             DateTime?
  batch              String?
  reviewBonusClaimed Boolean   @default(false)
  userId             String?
  user               User?     @relation(fields: [userId], references: [id])
  createdAt          DateTime  @default(now())

  @@index([code])
  @@index([isUsed])
  @@index([denomination])
  @@index([userId])
}
