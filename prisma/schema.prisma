// schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("USER")
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  name        String
  robuxAmount Int
  rubPrice    Float
  type        String
  isActive    Boolean  @default(true)
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  FAILED
}

model Order {
  id                 String      @id @default(cuid())
  userId             String?
  user               User?       @relation(fields: [userId], references: [id])
  customerRobloxUser String
  productId          String
  product            Product     @relation(fields: [productId], references: [id])
  amountRUB          Float
  amountRobux        Int
  tinkoffPaymentID   String?     @unique
  paymentUrl         String?
  status             OrderStatus @default(PENDING)
  botStatus          String?
  externalId         String?
  gamepassId         String?
  method             String
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id         String   @id @default(cuid())
  author     String
  content    String
  rating     Int      @default(5)
  date       String
  isVerified Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// --- NEW MODELS ---

/// Stores the latest scraped data from each supplier marketplace.
model MarketRate {
  id        String   @id @default(cuid())
  /// Unique identifier for the provider, e.g. "rbx120h" or "bossrobux"
  provider  String   @unique
  /// Rate in USD per 1000 Robux (or per transaction unit as seen on site)
  rateUSD   Float
  /// Total Robux available on the platform
  inventory Int
  /// Maximum Robux purchasable in one transaction
  maxLimit  Int
  updatedAt DateTime @updatedAt

  @@index([provider])
}

/// Global system settings — single-row config table.
/// Always upsert with id = "global".
model GlobalSettings {
  id          String   @id @default("global")
  /// Current USD → RUB exchange rate fetched from external API
  usdToRub    Float
  lastUpdated DateTime @updatedAt
}