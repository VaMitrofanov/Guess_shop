// schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id @default(cuid())
  vkId               String?   @unique
  tgId               String?   @unique
  email              String?   @unique
  password           String?
  name               String?
  image              String?
  balance            Int       @default(0)
  role               String    @default("USER")
  reviewBonusClaimed Boolean   @default(false)
  orders             Order[]
  wbCodes            WbCode[]
  wbOrders           WbOrder[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  name        String
  robuxAmount Int
  rubPrice    Float
  type        String
  isActive    Boolean  @default(true)
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  FAILED
}

model Order {
  id                 String      @id @default(cuid())
  userId             String?
  user               User?       @relation(fields: [userId], references: [id])
  customerRobloxUser String
  productId          String
  product            Product     @relation(fields: [productId], references: [id])
  amountRUB          Float
  amountRobux        Int
  tinkoffPaymentID   String?     @unique
  paymentUrl         String?
  status             OrderStatus @default(PENDING)
  botStatus          String?
  externalId         String?
  gamepassId         String?
  method             String
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

enum Platform {
  VK
  TG
}

enum WbOrderStatus {
  PENDING
  COMPLETED
  REJECTED
}

/// WB withdrawal order: tracks gamepass link submissions from WB card buyers.
model WbOrder {
  id          String        @id @default(cuid())
  amount      Int
  gamepassUrl String
  status      WbOrderStatus @default(PENDING)
  platform    Platform
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  wbCode      String
  adminId     String?
  rejectionReason String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId])
  @@index([status])
  @@index([wbCode])
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id         String   @id @default(cuid())
  author     String
  content    String
  rating     Int      @default(5)
  date       String
  isVerified Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// Stores the latest scraped data from each supplier marketplace.
model MarketRate {
  id        String   @id @default(cuid())
  provider  String   @unique
  rateUSD   Float
  inventory Int
  maxLimit  Int
  updatedAt DateTime @updatedAt

  @@index([provider])
}

/// Global system settings — single-row config table.
/// Always upsert with id = "global".
model GlobalSettings {
  id          String   @id @default("global")
  usdToRub    Float
  lastUpdated DateTime @updatedAt
}

/// Activation codes printed on Wildberries card inserts.
model WbCode {
  id                 String    @id @default(cuid())
  code               String    @unique
  denomination       Int
  isUsed             Boolean   @default(false)
  usedAt             DateTime?
  batch              String?
  reviewBonusClaimed Boolean   @default(false)
  userId             String?
  user               User?     @relation(fields: [userId], references: [id])
  createdAt          DateTime  @default(now())

  @@index([code])
  @@index([isUsed])
  @@index([denomination])
  @@index([userId])
}
