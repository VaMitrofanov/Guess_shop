# ────────────────────────────────────────────────────────────────────────────
# Build context exclusions for `docker build`.
# Anything matched here never enters the image — keeps build context small
# and prevents leaks of dev/secret files into the runtime image.
# ────────────────────────────────────────────────────────────────────────────

# --- Node / Next.js ---
node_modules
.next
out
.swc
.turbo

# --- Local environment / secrets ---
.env
.env.*
!.env.example

# --- VCS / IDE ---
.git
.gitignore
.gitattributes
.vscode
.idea
.DS_Store
*.swp

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Tests / coverage ---
coverage
.nyc_output
**/__tests__
**/*.test.ts
**/*.test.tsx
**/*.spec.ts

# --- Python automation engine + bots (live on the X280, not in the web image) ---
bots
venv
__pycache__
*.py
*.pyc
adspower.py
buyer.py
captcha_solver.py
config.py
parser.js
sheets.py
n8n_workflow.json
credentials.json
qr_wb_*.png

# --- Project metadata not needed at runtime ---
.claude
.agent
*.md
!README.md

# --- Docker meta ---
Dockerfile
.dockerignore
docker-compose*.yml
