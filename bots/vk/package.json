{
  "name": "robloxbank-vk-bot",
  "version": "1.0.0",
  "private": true,
  "description": "VK community bot \u2014 long-polling consumer for the RobloxBank shop. Deployed as an independent Docker service in Coolify.",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "start": "tsx bot.ts",
    "dev": "tsx watch bot.ts",
    "prisma:generate": "prisma generate --schema ../../prisma/schema.prisma",
    "prisma:generate:docker": "prisma generate --schema ./prisma/schema.prisma",
    "postinstall": "npm run prisma:generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.7.0",
    "dotenv": "^17.3.1",
    "pg": "^8.12.0",
    "vk-io": "^4.9.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.11.0",
    "prisma": "^7.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
